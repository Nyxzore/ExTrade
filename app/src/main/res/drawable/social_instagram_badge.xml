<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="45"
                android:centerColor="#dc2743"
                android:endColor="#bc1888"
                android:startColor="#f09433"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:width="22dp"
        android:height="22dp"
        android:gravity="center"
        android:drawable="@drawable/ic_instagram" />
</layer-list>
